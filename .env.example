# ─── Frontend (Vite) ────────────────────────────────────────────
VITE_BOTNOI_BOT_ID=6a013f62fb3079f00791473e
VITE_EVENTIQ_API_URL=http://localhost:3000
VITE_USE_MOCK_BACKEND=true

# Custom EventIQ API base — same origin in prod, localhost:3000 in dev when using `vercel dev`
VITE_AGENT_URL=/api

# ─── Backend (Vercel serverless functions) ──────────────────────
# Anthropic API key — used by /api/match for Claude rerank (Chunk 5+)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Shared secret for admin endpoints (/api/admin/*)
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN=

# Google Sheet id holding the canonical exhibitor data
GOOGLE_SHEET_ID=1Jez5HQ0SsPmvHoceEWTGHNIBdmUprR_1ImLNg9hNN78

# Apps Script Web App URL — exposed by the Sheet to allow writes back
# (deploy from sheet menu → Extensions → Apps Script → Deploy → Web app)
APPS_SCRIPT_WEBAPP_URL=
